xst -intstyle ise -ifn "D:/test111/SCCPU.xst" -ofn "D:/test111/SCCPU.syr" 
ngdbuild -intstyle ise -dd _ngo -nt timestamp -i -p xc7a100t-csg324-3 SCCPU.ngc SCCPU.ngd  
map -intstyle ise -p xc7a100t-csg324-3 -w -logic_opt off -ol high -t 1 -xt 0 -register_duplication off -r 4 -mt off -ir off -pr off -lc off -power off -o SCCPU_map.ncd SCCPU.ngd SCCPU.pcf 
par -w -intstyle ise -ol high -mt off SCCPU_map.ncd SCCPU.ncd SCCPU.pcf 
trce -intstyle ise -v 3 -s 3 -n 3 -fastpaths -xml SCCPU.twx SCCPU.ncd -o SCCPU.twr SCCPU.pcf 
bitgen -intstyle ise -f SCCPU.ut SCCPU.ncd 
